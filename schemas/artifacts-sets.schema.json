{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/artifacts-sets.schema.json",
  "title": "Artifact Sets",
  "type": "object",
  "required": ["artifact_sets"],
  "properties": {
    "artifact_sets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "pieces"],
              "properties": {
                "name": { "type": "string" },
                "pieces": { "type": "number" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "choose": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
