{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/build-notes.schema.json",
  "title": "Build Notes",
  "type": "object",
  "properties": {
    "artifact": {
      "type": "object",
      "properties": {
        "link": { "type": "string", "format": "uri" },
        "author": { "type": "string" }
      },
      "additionalProperties": false
    },
    "weapons": {
      "type": "object",
      "properties": {
        "link": { "type": "string", "format": "uri" },
        "author": { "type": "string" }
      },
      "additionalProperties": false
    },
    "talent": {
      "type": "object",
      "properties": {
        "link": { "type": "string", "format": "uri" },
        "author": { "type": "string" }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
