{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/artifacts-mainstats.schema.json",
  "title": "Artifact Main Stats",
  "type": "object",
  "required": ["main_stats"],
  "properties": {
    "main_stats": {
      "type": "object",
      "required": ["sands", "goblet", "circlet"],
      "properties": {
        "sands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "goblet": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "circlet": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
