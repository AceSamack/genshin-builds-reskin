---
import { t } from '../utils/i18n';
import { sitePath } from '../utils/paths';
import ImageButton from './ImageButton.astro';

const { latestVersion = '', locale, recentlyUpdatedCount = 0 } = Astro.props;
const hasRecentUpdates = recentlyUpdatedCount > 0;
const recentlyUpdatedLabel = t(
  locale,
  'ui',
  'Recently updated',
  undefined,
  false,
);
const versionLabel = t(locale, 'ui', 'Version', undefined, false);
const versionText = latestVersion ? `${versionLabel} ${latestVersion}` : '';

// Filter options mirror metadata values written onto each character card.
const elements = ['anemo', 'cryo', 'dendro', 'electro', 'geo', 'hydro', 'pyro'];
const rarities = ['4', '5'];
const weapons = ['bow', 'catalyst', 'claymore', 'polearm', 'sword'];
const allLabel = t(locale, 'ui', 'All');

const elementOptions = elements.map((element) => ({
  value: element,
  label: t(locale, 'element', element),
  icon: `${element.charAt(0).toUpperCase()}${element.slice(1)}`,
}));
const rarityOptions = [
  { value: '', label: allLabel },
  ...rarities.map((rarity) => ({
    value: rarity,
    label: `${rarity}★`,
  })),
];
const weaponOptions = weapons.map((weapon) => ({
  value: weapon,
  label: t(locale, 'ui', weapon),
  icon: `${weapon.charAt(0).toUpperCase()}${weapon.slice(1)}`,
}));
---

<form class="home-filters" id="character-filters" data-character-filters>
  <div class="home-filters-top toolbar">
    <label class="home-search">
      {t(locale, 'ui', 'Search')}
      <input
        type="search"
        name="search"
        placeholder={t(locale, 'ui', 'Search by name')}
        autocomplete="off"
      />
    </label>

    {
      hasRecentUpdates && (
        <label class="home-updated-toggle">
          <input
            class="home-updated-toggle-input"
            type="checkbox"
            name="updated"
            value="true"
          />
          <span class="home-updated-toggle-mark" aria-hidden="true" />
          <span class="home-updated-text">
            <span class="home-updated-toggle-title">{recentlyUpdatedLabel}</span>
            {versionText && (
              <span class="home-updated-toggle-version">{versionText}</span>
            )}
          </span>
          <span class="home-updated-toggle-count">{recentlyUpdatedCount}</span>
        </label>
      )
    }
  </div>

  <div class="home-filter-buttons-combined">
    <div class="home-filter-group-inline">
      <input
        type="hidden"
        name="element"
        value=""
        data-element-filter-value
      />
      <div class="home-filter-buttons" data-element-buttons>
        {
          elementOptions.map((option) => (
            <ImageButton
              type="button"
              src={sitePath(`icons/${option.icon}.webp`)}
              alt={option.label}
              ariaLabel={option.label}
              title={option.label}
              pressed={false}
              class={`home-filter-button home-element-button home-filter-button-${option.value}`}
              data-element-value={option.value}
            />
          ))
        }
      </div>
    </div>

    <div class="home-filter-group-inline">
      <input
        type="hidden"
        name="weapon"
        value=""
        data-weapon-filter-value
      />
      <div class="home-filter-buttons" data-weapon-buttons>
        {
          weaponOptions.map((option) => (
            <ImageButton
              type="button"
              src={sitePath(`icons/${option.icon}.webp`)}
              alt={option.label}
              ariaLabel={option.label}
              title={option.label}
              pressed={false}
              class={`home-filter-button home-weapon-button home-filter-button-${option.value}`}
              data-weapon-value={option.value}
            />
          ))
        }
      </div>
    </div>
    
    <div class="home-filter-group-inline">
      <input
        type="hidden"
        name="rarity"
        value=""
        data-rarity-filter-value
      />
      <div class="home-filter-buttons" data-rarity-buttons>
        {
          rarities.map((rarity) => (
            <ImageButton
              type="button"
              src={sitePath(`icons/rarity-${rarity}.svg`)}
              alt={`${rarity}★`}
              ariaLabel={`${rarity}★`}
              title={`${rarity}★`}
              pressed={false}
              class={`home-filter-button home-rarity-button`}
              data-rarity-value={rarity}
            />
          ))
        }
      </div>
    </div>
  </div>
</form>

<style>
  .home-filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .home-filter-button {
    justify-self: center;
  }
</style>

<script>
  import { initFilterButtons } from '../utils/home-page';
  initFilterButtons('[data-element-value]', '[data-element-filter-value]', 'elementValue');
  initFilterButtons('[data-weapon-value]', '[data-weapon-filter-value]', 'weaponValue');
  initFilterButtons('[data-rarity-value]', '[data-rarity-filter-value]', 'rarityValue');
</script>
