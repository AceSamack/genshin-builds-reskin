---
import { t } from '../utils/i18n';
import { sitePath } from '../utils/paths';
import ImageButton from './ImageButton.astro';

const { latestVersion = '', locale, recentlyUpdatedCount = 0 } = Astro.props;
const hasRecentUpdates = recentlyUpdatedCount > 0;
const recentlyUpdatedLabel = t(
  locale,
  'ui',
  'Recently updated',
  undefined,
  false,
);
const versionLabel = t(locale, 'ui', 'Version', undefined, false);
const versionText = latestVersion ? `${versionLabel} ${latestVersion}` : '';

// Filter options mirror metadata values written onto each character card.
const elements = ['anemo', 'cryo', 'dendro', 'electro', 'geo', 'hydro', 'pyro'];
const rarities = ['4', '5'];
const weapons = ['bow', 'catalyst', 'claymore', 'polearm', 'sword'];
const allLabel = t(locale, 'ui', 'All');

const elementOptions = elements.map((element) => ({
  value: element,
  label: t(locale, 'element', element),
  icon: `${element.charAt(0).toUpperCase()}${element.slice(1)}`,
}));
const rarityOptions = [
  { value: '', label: allLabel },
  ...rarities.map((rarity) => ({
    value: rarity,
    label: `${rarity}★`,
  })),
];
const weaponOptions = weapons.map((weapon) => ({
  value: weapon,
  label: t(locale, 'ui', weapon),
  icon: `${weapon.charAt(0).toUpperCase()}${weapon.slice(1)}`,
}));
---

<form class="home-filters" data-character-filters>
  <div class="home-filters-top toolbar">
    <label class="home-search">
      {t(locale, 'ui', 'Search')}
      <input
        type="search"
        name="search"
        placeholder={t(locale, 'ui', 'Search by name')}
        autocomplete="off"
      />
    </label>

  {
    hasRecentUpdates && (
      <label class="home-updated-toggle">
        <input
          class="home-updated-toggle-input"
          type="checkbox"
          name="updated"
          value="true"
        />
        <span class="home-updated-toggle-mark" aria-hidden="true" />
        <span class="home-updated-text">
          <span class="home-updated-toggle-title">{recentlyUpdatedLabel}</span>
          {versionText && (
            <span class="home-updated-toggle-version">{versionText}</span>
          )}
        </span>
        <span class="home-updated-toggle-count">{recentlyUpdatedCount}</span>
      </label>
    )
  }
</form>

<style>
  .home-filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .home-filter-button {
    justify-self: center;
  }
</style>

<script>
  function initFilterButtons(buttonSelector: string, inputSelector: string, valueAttr: string) {
    const buttons = document.querySelectorAll<HTMLButtonElement>(buttonSelector);
    const valueInput = document.querySelector<HTMLInputElement>(inputSelector);

    if (buttons.length && valueInput) {
      const setActive = (value: string) => {
        valueInput.value = value;
        buttons.forEach((button) => {
          const isActive = button.dataset[valueAttr] === value;
          button.setAttribute('aria-pressed', String(isActive));
        });
        valueInput.dispatchEvent(new Event('change', { bubbles: true }));
      };

      setActive('');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const value = button.dataset[valueAttr] ?? '';
          setActive(valueInput.value === value ? '' : value);
        });
      });
    }
  }

  initFilterButtons('[data-element-value]', '[data-element-filter-value]', 'elementValue');
  initFilterButtons('[data-weapon-value]', '[data-weapon-filter-value]', 'weaponValue');
  initFilterButtons('[data-rarity-value]', '[data-rarity-filter-value]', 'rarityValue');
</script>
