---
export interface Props {
  src: string;
  alt: string;
  ariaLabel?: string;
  title?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  toggle?: boolean;
  pressed?: boolean;
}

const {
  src,
  alt,
  ariaLabel,
  title,
  type = 'button',
  class: className = '',
  toggle = false,
  pressed,
  ...rest
} = Astro.props;

const buttonLabel = ariaLabel ?? alt;
const hasPressedState = typeof pressed === 'boolean';
---

<button
  type={type}
  class={`image-button ${className}`.trim()}
  aria-label={buttonLabel}
  title={title ?? buttonLabel}
  aria-pressed={hasPressedState ? String(pressed) : undefined}
  data-image-button-toggle={toggle ? '' : undefined}
  {...rest}
>
  <img src={src} alt={alt} loading="eager" decoding="async" fetchpriority="high" />
</button>

<style>
  .image-button {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 3.5rem;
    height: 3.5rem;
    min-width: 3.5rem;
    min-height: 3.5rem;
    border: 1px solid color-mix(in srgb, var(--text) 16%, transparent);
    border-radius: 20px;
    padding: 0.6rem;
    background:
      radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.14), transparent 42%),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.06),
        rgba(255, 255, 255, 0.02)
      ),
      rgba(9, 13, 19, 0.72);
    cursor: pointer;
    line-height: 0;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 10px 18px rgba(0, 0, 0, 0.18);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      background 0.16s ease,
      box-shadow 0.16s ease;
  }

  @media (max-width: 640px) {
    .image-button {
      width: 2.8rem;
      height: 2.8rem;
      min-width: 2.8rem;
      min-height: 2.8rem;
      padding: 0.4rem;
    }
  }


  .image-button::after {
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    border-radius: inherit;
    pointer-events: none;
    content: '';
  }

  .image-button img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: saturate(0.9) brightness(0.95);
    transition: transform 0.16s ease, filter 0.16s ease;
    pointer-events: none;
    user-select: none;
  }

  .image-button:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent) 28%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 12px 20px rgba(0, 0, 0, 0.22);
  }

  .image-button:hover img {
    filter: grayscale(0.1) saturate(1.05) brightness(0.98);
  }

  .image-button:active {
    transform: translateY(1px) scale(0.98);
  }

  .image-button[aria-pressed='true'] {
    border-color: color-mix(in srgb, var(--accent) 84%, white 10%);
    background:
      radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.28), transparent 38%),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--accent) 48%, rgba(255, 255, 255, 0.08)),
        color-mix(in srgb, var(--accent) 24%, rgba(255, 255, 255, 0.04))
      ),
      rgba(18, 11, 8, 0.96);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 0 0 2px color-mix(in srgb, var(--accent) 36%, transparent),
      0 0 0 6px color-mix(in srgb, var(--accent) 10%, transparent),
      0 16px 28px rgba(0, 0, 0, 0.34);
  }

  .image-button[aria-pressed='true'] img {
    filter:
      grayscale(0) saturate(1.55) brightness(1.15)
      drop-shadow(0 0 12px rgba(255, 145, 80, 0.32));
    transform: scale(1.04);
  }

  .image-button[aria-pressed='true']::after {
    border-color: color-mix(in srgb, var(--accent) 68%, white 10%);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .image-button:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 72%, white 8%);
    outline-offset: 2px;
  }

  .image-button[aria-pressed='true']:focus-visible {
    outline-color: color-mix(in srgb, var(--accent) 86%, white 8%);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    '[data-image-button-toggle]',
  );

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextState = button.getAttribute('aria-pressed') !== 'true';

      button.setAttribute('aria-pressed', String(nextState));
    });
  });
</script>
