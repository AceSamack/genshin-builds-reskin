---
const { title, id } = Astro.props;
---

<div class="build-card" data-id={id}>
  <button class="build-header">
    <span class="arrow">▸</span>
    {title}
  </button>

  <div class="build-content">
    <slot />
  </div>
</div>

<script is:inline>
  const cards = document.querySelectorAll('.build-card');

  function openCard(targetId) {
    cards.forEach((card) => {
      const isTarget = card.dataset.id === targetId;
      card.classList.toggle('open', isTarget);
    });
  }

  // click handling
  cards.forEach((card) => {
    const btn = card.querySelector('.build-header');

    btn.addEventListener('click', () => {
      const id = card.dataset.id;
      const isOpen = card.classList.contains('open');

      const newState = isOpen ? null : id;

      const url = new URL(window.location);
      if (newState) url.searchParams.set('build', newState);
      else url.searchParams.delete('build');

      window.history.pushState({}, '', url);

      openCard(newState);
    });
  });

  // URL sync on load
  const params = new URLSearchParams(window.location.search);
  const initial = params.get('build');

  if (initial) openCard(initial);
</script>
