---
import SimplePageLayout from '../../layouts/SimplePageLayout.astro';
import FaqContent from '../../components/FaqContent.astro';
import { getLocale } from '../../utils/i18n';

const lang = Astro.params.lang ?? 'en';
const locale = getLocale(lang);
---

<SimplePageLayout title={locale.ui.FAQ} lang={lang} locale={locale} page="faq">
  <FaqContent lang={lang} />
</SimplePageLayout>
