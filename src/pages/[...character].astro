---
import fs from 'fs';
import path from 'path';
import Weapon from '../components/Weapon.astro';
import BuildCard from '../components/BuildCard.astro';
import Artifact from '../components/Artifact.astro';
import Talent from '../components/Talent.astro';
import Notes from '../components/Notes.astro';
import { marked } from 'marked';

import CharacterPageLayout from '../layouts/CharacterLayout.astro';

export const prerender = false;

function loadJSON(buildPath: string, fileName: string) {
  const buildFile = path.join(buildPath, fileName);
  const charFile = path.join(path.dirname(buildPath), fileName);

  if (fs.existsSync(buildFile)) {
    return JSON.parse(fs.readFileSync(buildFile, 'utf-8'));
  }

  if (fs.existsSync(charFile)) {
    return JSON.parse(fs.readFileSync(charFile, 'utf-8'));
  }

  return null;
}

const toTitleCase = (str: string) =>
  str
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');

const { character } = Astro.params;

if (!character) {
  throw new Error('Character parameter is required');
}

const char = character.toLowerCase();

const base = path.resolve('content');

let foundPath = null;

outer: for (const element of fs.readdirSync(base)) {
  for (const rarity of fs.readdirSync(path.join(base, element))) {
    const candidate = path.join(base, element, rarity, char);

    if (fs.existsSync(candidate)) {
      foundPath = { element, rarity, path: candidate };
      break outer;
    }
  }
}

if (!foundPath) {
  throw new Error('Character not found');
}

const metadata = loadJSON(foundPath.path, 'metadata.json');

const builds = fs
  .readdirSync(foundPath.path)
  .filter((f) => fs.statSync(path.join(foundPath.path, f)).isDirectory());

const data = builds.map((build) => {
  const p = path.join(foundPath.path, build);

  const weapons = loadJSON(p, 'weapons.json');

  const artifacts = {
    sets: loadJSON(p, 'artifacts-sets.json'),
    mainstats: loadJSON(p, 'artifacts-mainstats.json'),
    substats: loadJSON(p, 'artifacts-substats.json'),
  };

  const talents = loadJSON(p, 'talents.json');

  function collectNotes(groups: any, formatter: any) {
    const notes: { name: string; note: string }[] = [];

    groups.forEach((group: { items: any[] }) => {
      group.items.forEach((item: { note: string }) => {
        if (item.note) {
          notes.push({
            name: formatter(item),
            note: (marked.parse(item.note) as string).replace(/<\/?p>/g, ''),
          });
        }
      });
    });

    return notes;
  }

  function collectStatNotes(items: any[], formatter: any) {
    const notes: { name: string; note: string }[] = [];

    items.forEach((item) => {
      const note = typeof item === 'string' ? null : item.note;

      if (note) {
        notes.push({
          name: formatter(item),
          note: (marked.parse(note) as string).replace(/<\/?p>/g, ''),
        });
      }
    });

    return notes;
  }

  return {
    name: build,

    weapons,
    artifacts,
    talents,

    notes: {
      weapons: collectNotes(weapons.weapons, (w: { name: any }) => w.name),

      artifacts: {
        sets: collectNotes(
          artifacts.sets.artifact_sets,
          (a: { name: any; pieces: any }) => `${a.name} (${a.pieces})`,
        ),
        mainstats: [
          ...collectStatNotes(
            artifacts.mainstats.main_stats.sands,
            (s: { name: any }) => s.name,
          ),
          ...collectStatNotes(
            artifacts.mainstats.main_stats.goblet,
            (s: { name: any }) => s.name,
          ),
          ...collectStatNotes(
            artifacts.mainstats.main_stats.circlet,
            (s: { name: any }) => s.name,
          ),
        ],
        substats: collectStatNotes(
          artifacts.substats.substats_priority,
          (s: any) => (typeof s === 'string' ? s : s.name),
        ),
      },

      talents: collectNotes(talents.talents, (t: { name: any }) => t.name),
    },

    buildNote: loadJSON(p, 'build-notes.json')
      ? {
          ...loadJSON(p, 'build-notes.json'),
          notes: loadJSON(p, 'build-notes.json').notes?.map((n: string) =>
            marked.parse(n),
          ),
        }
      : null,
  };
});
---

<CharacterPageLayout
  character={toTitleCase(character)}
  metadata={metadata}
  element={foundPath.element}
>
  {
    data.map((b) => (
      <BuildCard title={toTitleCase(b.name)} id={b.name}>
        <div class="grid">
          <Weapon weapons={b.weapons} />
          <Artifact artifacts={b.artifacts} />
          <Talent talents={b.talents} />
        </div>

        <Notes notes={b.notes} buildNote={b.buildNote} />
      </BuildCard>
    ))
  }
</CharacterPageLayout>
